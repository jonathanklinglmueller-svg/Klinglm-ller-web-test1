<!DOCTYPE html>
<html lang="de">
<head>
  <meta charset="UTF-8">
  <title>Test</title>
</head>
<body style="background-color: lightblue;">

  <h1>Jonathan Klinglmüller – 5R</h1>

  <h2>Lieblingsfarbe und Geburtsdatum</h2>
  <p>7.31.2011</p>
  <p>Blau</p>

  <h2>Fächer</h2>
  <ol>
    <li>Sport</li>
    <li>Mathe</li>
    <li>Ethik</li>
  </ol>

  <h2>Hobys</h2>
  <ul id="liste-hobbys"></ul>

  <h2>Freies Bild</h2>
  <figure>
    <img src="img/bild1.jpg" width="400" height="auto" title="Freies Bild" alt="Uhrhebr rechte und link zu dem bild">
    <figcaption>
      Foto von <a href="https://www.istockphoto.com/de">iStock</a>,
      <a href="https://www.istockphoto.com/photo/soccer-player-putting-sports-ball-on-grass-gm1777139484-546422127">Soccer player putting sports ball on grass stock photo</a>,
      <a href="https://creativecommons.org/licenses/by/4.0/">CC BY 4.0</a>
    </figcaption>
  </figure>

  <script>
    const hobbys = ["Fußball", "Gaming", "Lesen"];
    const liste = document.getElementById("liste-hobbys");
    hobbys.forEach(h => {
      let li = document.createElement("li");
      li.textContent = h;
      liste.appendChild(li);
    });
  </script>

</body>
</html>
